{
  "name": "react-router-adapters",
  "version": "0.1.1",
  "description": "Server framework adapters for React Router",
  "keywords": [
    "adapter",
    "elysia",
    "h3",
    "hono",
    "react-router",
    "server",
    "vite"
  ],
  "homepage": "https://github.com/ssssota/react-router-adapters#readme",
  "bugs": {
    "url": "https://github.com/ssssota/react-router-adapters/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssssota/react-router-adapters.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./elysia": {
      "types": "./dist/elysia.d.mts",
      "default": "./dist/elysia.mjs"
    },
    "./h3": {
      "types": "./dist/h3.d.mts",
      "default": "./dist/h3.mjs"
    },
    "./hono": {
      "types": "./dist/hono.d.mts",
      "default": "./dist/hono.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "fmt": "oxfmt && oxlint --fix",
    "check": "oxfmt --check && oxlint && tsc && pnpm -r typecheck",
    "test": "pnpm -r test",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@remix-run/node-fetch-server": "^0.13.3"
  },
  "devDependencies": {
    "@elysia/node": "^1.4.6",
    "@hono/node-server": "^2.0.4",
    "@types/node": "^24.0.0",
    "elysia": "^1.4.28",
    "h3": "2.0.1-rc.22",
    "hono": "^4.12.25",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "react-router": "7.16.0",
    "tsdown": "^0.22.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  },
  "peerDependencies": {
    "@elysia/node": ">=1.0.0 <2.0.0",
    "@hono/node-server": ">=2.0.0 <3.0.0",
    "elysia": ">=1.4.0 <2.0.0",
    "h3": ">=2.0.0-rc.22 <3.0.0",
    "hono": ">=4.0.0 <5.0.0",
    "react-router": ">=7.0.0 <8.0.0",
    "vite": ">=8.0.0 <9.0.0"
  },
  "peerDependenciesMeta": {
    "@elysia/node": {
      "optional": true
    },
    "@hono/node-server": {
      "optional": true
    },
    "elysia": {
      "optional": true
    },
    "h3": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
